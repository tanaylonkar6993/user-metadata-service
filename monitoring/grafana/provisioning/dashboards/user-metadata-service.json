{
  "title": "User Metadata Service",
  "uid": "user-metadata-svc",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "user_service_requests_total",
        "legendFormat": "Total"
      }]
    },
    {
      "id": 2,
      "title": "Success vs Failure",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "user_service_success_total", "legendFormat": "Success" },
        { "expr": "user_service_failure_total", "legendFormat": "Failure" }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency P99 (ms)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(user_service_request_latency_ms_bucket[5m])) * 1000",
        "legendFormat": "P99"
      }]
    },
    {
      "id": 4,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "user_service_circuit_breaker_open",
        "legendFormat": "CB Open (1=OPEN)"
      }]
    },
    {
      "id": 5,
      "title": "DB Retry Count",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "user_service_db_retry_total",
        "legendFormat": "Retries"
      }]
    },
    {
      "id": 6,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(user_service_requests_total[1m])", "legendFormat": "Total req/s" },
        { "expr": "rate(user_service_success_total[1m])", "legendFormat": "Success req/s" },
        { "expr": "rate(user_service_failure_total[1m])", "legendFormat": "Failure req/s" }
      ]
    },
    {
      "id": 7,
      "title": "Latency Percentiles (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(user_service_request_latency_ms_bucket[5m])) * 1000", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(user_service_request_latency_ms_bucket[5m])) * 1000", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(user_service_request_latency_ms_bucket[5m])) * 1000", "legendFormat": "P99" }
      ]
    }
  ]
}
